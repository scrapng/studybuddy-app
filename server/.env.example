# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-key-here

# Supabase Configuration (get from Supabase Dashboard > Settings > API)
# SUPABASE_URL: Project URL (e.g. https://abcdefgh.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY: service_role JWT key starting with eyJ... (NOT the DB connection string)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS - Frontend URL(s), comma-separated
ALLOWED_ORIGINS=https://your-app.vercel.app

# Server Configuration
PORT=3001
NODE_ENV=development
